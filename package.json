{
    "name": "unlox-root",
    "version": "1.0.0",
    "description": "Root package to manage and run both frontend and backend for Unlox project",
    "scripts": {
        "backend": "npm run dev --prefix backend",
        "frontend": "npm run dev --prefix frontend",
        "dev": "concurrently \"npm run backend\" \"npm run frontend\""
    },
    "devDependencies": {
        "concurrently": "^8.2.2"
    }
}